---
import type { CollectionEntry } from 'astro:content';
import Icon from '../components/Icon.astro';

interface Props {
    engagement: CollectionEntry<'engagement'>;
}

const { data, slug } = Astro.props.engagement;

function formatPeriod(startDate: Date, endDate: Date): string {
    const totalMonths =
        (endDate.getFullYear() - startDate.getFullYear()) * 12 +
        (endDate.getMonth() - startDate.getMonth());
    const years = Math.floor(totalMonths / 12);
    const months = totalMonths % 12;
    const parts: string[] = [];
    if (years > 0) parts.push(`${years} yr${years !== 1 ? 's' : ''}`);
    if (months > 0) parts.push(`${months} mo`);
    const duration = parts.length ? ` · ${parts.join(' ')}` : '';

    const fmt = (d: Date) => d.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
    return `${fmt(startDate)} – ${fmt(endDate)}${duration}`;
}
---

<a class="card" href={`/engagements/${slug}`}>
    <div class="card-inner">
        <div class="card-header">
            <span class="employer">{data.employer}</span>
            <span class="employment-type">{data.employment}</span>
        </div>
        <div class="role">{data.role}</div>
        <div class="meta">
            <span>
                <Icon icon="calendar" size="0.9em" />
                {formatPeriod(data.startDate, data.endDate)}
            </span>
            <span>
                <Icon icon="map-pin" size="0.9em" />
                {data.location}
            </span>
        </div>
        {
            data.tags?.length && (
                <div class="tags">
                    {data.tags.map(tag => (
                        <span class="tag">{tag}</span>
                    ))}
                </div>
            )
        }
    </div>
    <div class="card-arrow">
        <Icon icon="arrow-right" size="1.2em" />
    </div>
</a>

<style>
    .card {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.5rem;
        background: var(--gradient-subtle);
        border: 1px solid var(--gray-800);
        border-left: 3px solid var(--accent-regular);
        border-radius: 0.75rem;
        text-decoration: none;
        color: var(--gray-200);
        box-shadow: var(--shadow-sm);
        transition:
            box-shadow var(--theme-transition),
            border-left-color var(--theme-transition);
    }

    .card:hover {
        box-shadow: var(--shadow-md);
        border-left-color: var(--accent-text-over);
    }

    .card-inner {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .employer {
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--accent-regular);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .employment-type {
        font-size: var(--text-sm);
        color: var(--gray-400);
        border: 1px solid var(--gray-700);
        border-radius: 999rem;
        padding: 0.1rem 0.6rem;
        white-space: nowrap;
    }

    .role {
        font-weight: 600;
        font-family: var(--font-brand);
        font-size: var(--text-lg);
        color: var(--gray-0);
        line-height: 1.3;
    }

    .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
        font-size: var(--text-sm);
        color: var(--gray-400);
    }

    .meta span {
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.25rem;
    }

    .tag {
        font-size: 0.72rem;
        padding: 0.15rem 0.65rem;
        border-radius: 999rem;
        background: var(--accent-overlay);
        color: var(--accent-text-over);
        font-weight: 500;
    }

    .card-arrow {
        color: var(--gray-600);
        flex-shrink: 0;
        margin-top: 0.2rem;
        transition:
            color var(--theme-transition),
            transform var(--theme-transition);
    }

    .card:hover .card-arrow {
        color: var(--accent-regular);
        transform: translateX(3px);
    }

    @media (min-width: 50em) {
        .card {
            border-radius: 1rem;
        }
    }
</style>
