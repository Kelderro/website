{
    "name": "kelderro-website",
    "packageManager": "pnpm@10.33.0",
    "type": "module",
    "version": "2026.01.0001",
    "scripts": {
        "dev": "astro dev --host 0.0.0.0",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "astro check",
        "validate": "npm run lint && npm run format:check && npm run type-check",
        "prepare": "husky",
        "debug": "astro dev --host 0.0.0.0 --env-mode debug",
        "test": "playwright test --headed"
    },
    "dependencies": {
        "@astrojs/mdx": "^7.0.2",
        "@astrojs/sitemap": "^3.7.3",
        "marked": "^15.0.12",
        "@sentry/astro": "^10.65.0",
        "@sentry/cloudflare": "^10.65.0",
        "@spotlightjs/astro": "^3.2.6",
        "astro": "^7.0.7",
        "sharp": "^0.35.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "astro-eslint-parser": "^2.1.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^2.1.1",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.5",
        "prettier-plugin-astro": "^0.14.1",
        "simple-icons": "^16.25.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "wrangler": "^4.110.0"
    },
    "lint-staged": {
        "*.{js,ts,astro}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": [
            "prettier --write"
        ],
        "src/**/__tests__/*.spec.ts": [
            "pnpm exec playwright test"
        ]
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    }
}
