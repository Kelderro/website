{
    "ci": {
        "collect": {
            "numberOfRuns": 1,
            "settings": {
                "extraHeaders": {
                    "CF-Access-Client-Id": "__CF_ID__",
                    "CF-Access-Client-Secret": "__CF_SECRET__"
                }
            }
        },
        "assert": {
            "preset": "lighthouse:recommended"
        }
    }
}
