{
    "name": "kelderro-website",
    "build": {
        "dockerfile": "Dockerfile"
    },

    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {}
    },

    "mounts": [
        // 1. High-speed volume for node_modules
        "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
        // 2. High-speed volume for the pnpm store
        "source=pnpm-global-store,target=/home/node/.local/share/pnpm/store,type=volume"
    ],

    "postCreateCommand": "sudo chown -R node node_modules /home/node/.local/share/pnpm &&pnpm install && pnpm exec playwright install --with-deps chromium && pnpm run build",
    "waitFor": "postCreateCommand",

    "forwardPorts": [4321],

    "portsAttributes": {
        "4321": {
            "label": "Astro Dev Server",
            "onAutoForward": "notify",
            "elevateIfNeeded": true
        }
    },

    "remoteUser": "node",

    "customizations": {
        "vscode": {
            "extensions": [
                "astro-build.astro-vscode", // Official Astro support
                "dbaeumer.vscode-eslint", // Linting
                "esbenp.prettier-vscode" // Code formatting
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "esbenp.prettier-vscode"
            }
        }
    }
}
